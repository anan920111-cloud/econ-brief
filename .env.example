# DeepSeek API Key (required)
# Get your key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# Optional: DeepSeek base URL (defaults to https://api.deepseek.com)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: Model selection
# SCORER_MODEL=deepseek-chat       # Stage 1: fast scoring (default)
# ANALYZER_MODEL=deepseek-chat     # Stage 2: deep analysis (default)
# ANALYZER_MODEL=deepseek-reasoner # Stage 2: higher quality with R1

# OpenAlex polite pool email (optional, for higher rate limits)
OPENALEX_EMAIL=your@email.com

# SMTP Configuration (for email delivery)
SMTP_HOST=smtp.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_login
SMTP_PASSWORD=your_smtp_password

# Email addresses
EMAIL_FROM=econ-brief@example.com
EMAIL_TO=your@email.com

# Optional: adjust pipeline behavior
LOOKBACK_DAYS=3
MIN_RELEVANCE_SCORE=6.0
MAX_STAGE2_PAPERS=30
